# 토우리 환경변수 템플릿
# 사용법: 이 파일을 복사해서 .env 로 이름 바꾸고 실제 키 넣기
# 절대 .env 파일을 커밋하지 말 것 (.gitignore에 포함됨)

# Anthropic Claude API (AI 챗봇)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Supabase (백엔드)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# Meshy AI (3D 변환, 선택)
MESHY_API_KEY=msy_xxxxx

# Firebase (APK 자동 배포, 선택)
FIREBASE_APP_ID=1:xxx:android:xxx
